{
  "name": "@codeagora/tui",
  "version": "2.0.0-rc.13",
  "description": "CodeAgora interactive terminal UI — ink-based review interface",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bssm-oss/CodeAgora.git",
    "directory": "packages/tui"
  },
  "homepage": "https://github.com/bssm-oss/CodeAgora#readme",
